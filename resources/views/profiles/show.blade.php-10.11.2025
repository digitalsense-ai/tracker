<!doctype html><html><head><meta charset='utf-8'><title>Profile</title></head><body><h1>{{ $profile->name }}</h1><pre>{{ json_encode($profile->settings,JSON_PRETTY_PRINT) }}</pre><h2>Results</h2><table><tr><th>Date</th><th>Trades</th><th>Win%</th><th>Net</th></tr>@foreach($history as $h)<tr><td>{{ $h->created_at }}</td><td>{{ $h->trades }}</td><td>{{ number_format($h->winrate,1) }}%</td><td>{{ number_format($h->net_pl,2) }}</td></tr>@endforeach</table></body></html>